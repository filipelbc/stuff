(add-to-list 'load-path "/usr/share/emacs/site-lisp/org")

(eval-after-load "org"
    '(require 'ox-gfm nil t)
)

(setq
    system-time-locale "C"
    org-html-postamble nil
    org-confirm-babel-evaluate nil
    org-babel-python-command "python3"

    make-backup-files nil
    auto-save-default nil

    org-plantuml-jar-path (expand-file-name "~/bin/java/plantuml.jar")
)

(org-babel-do-load-languages
    'org-babel-load-languages '(
        (python . t)
        (dot . t)
        (shell . t)
        (plantuml . t)
    )
)

; Override the default src block error handling function in order to make
; export fail.
(defun org-babel-eval-error-notify (exit-code stderr)
    (error "Babel evaluation exited with code %S:\n%s" exit-code stderr))

; Override the default template for the UP and HOME links of the HTML export
(setq
    org-html-home/up-format
    "<div id='org-div-home-and-up'>
        <ul>
            <li id='navUp'><a accesskey='u' href='%s'>Up</a></li>
            <li id='navHome'><a accesskey='h' href='%s'>Home</a></li>
        </ul>
    </div>")
